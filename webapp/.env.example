# Copy to .env and override only if needed. Defaults are set in code.

# Our Text-to-Multiple-Languages API
# VITE_TRANSLATE_API_URL=https://t3jb8c44xi.execute-api.us-east-1.amazonaws.com

# Classmate's Image-to-Text API (from https://main.d106ktv35b9lnn.amplifyapp.com)
# Default in code: https://xkdvpogqt0.execute-api.us-east-1.amazonaws.com/prod
# VITE_IMAGE_TO_TEXT_API_URL=https://xkdvpogqt0.execute-api.us-east-1.amazonaws.com/prod

# Firebase Auth (optional – enables Sign in with Google). Get from Firebase Console > Project settings.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
