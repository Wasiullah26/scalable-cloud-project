# AWS credentials (e.g. from Learner Lab). Copy this file to .env and fill in.
# Do not commit .env to git.

AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here

# Optional: default region
AWS_REGION=us-east-1

# If your account can't create IAM roles (e.g. Learner Lab), use an existing role ARN.
# Find it: AWS Console → IAM → Roles → click your role → copy "Role ARN"
# LAMBDA_ROLE_ARN=arn:aws:iam::123456789012:role/YourLabRole

# Optional: override default names
# LAMBDA_FUNCTION_NAME=text-to-languages-api
# API_NAME=text-to-languages-api
# LAMBDA_ROLE_NAME=text-to-languages-lambda-role

# JWT secret for auth (login/signup). Set a strong value in production.
# JWT_SECRET=your-secret-key

# DynamoDB table names (used for both local and Lambda). Run deploy once to create tables.
# TRANSLATIONS_TABLE=translations
# USERS_TABLE=users
